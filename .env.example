# Copy this file to .env and fill in your real values.
# .env is gitignored and will never be committed.

# ─── TikTok Commercial Content API ──────────────────────────────────────────
# Get from: https://developers.tiktok.com/  (Research API access required)
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here

# ─── Meta Ad Library API ────────────────────────────────────────────────────
# Get from: https://www.facebook.com/ads/library/api/
META_ACCESS_TOKEN=your_meta_access_token_here

# ─── Anthropic (optional — only for classify_ads.py AI scoring) ─────────────
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── Data paths (override if your DB / creatives live outside the repo) ────
POLITICIAN_ADS_DB=politician_ads.db
TIKTOK_CREATIVES_DIR=./creatives
